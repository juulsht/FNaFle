@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="background-blur"></div>

<div class="top-bar">
    <div class="night-box">
        <span class="night-label">Night</span>
        <span class="night-value">—</span>
    </div>
</div>

<div class="auth-wrapper">
    <div class="auth-card">
        <h1 class="auth-title">Create account</h1>

        <form method="post" asp-route-returnUrl="@Model.ReturnUrl">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input asp-for="Input.Email" class="auth-input" placeholder="Email" autocomplete="username" />
            <span asp-validation-for="Input.Email" class="text-danger"></span>

            <input asp-for="Input.Password" class="auth-input" placeholder="Password" autocomplete="new-password" />
            <span asp-validation-for="Input.Password" class="text-danger"></span>

            <input asp-for="Input.ConfirmPassword" class="auth-input" placeholder="Confirm password" autocomplete="new-password" />
            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>

            <div class="auth-actions">
                <button type="submit" class="auth-box">Register</button>
                <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="auth-link">Have an account? Login</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
 }
