@{
    ViewData["Title"] = "FNaFle";
    int streak = ViewBag.Streak ?? 0;
}

<div class="background-blur"></div>

<div class="top-bar">
    <div class="left-buttons" style="display:flex; gap:12px; align-items:center;">
        <div class="night-box">
            <span class="night-label">Night</span>
            <span class="night-value">@streak</span>
        </div>
        <a asp-controller="Characters" asp-action="Index" class="auth-box">Library</a>
        <a asp-controller="Home" asp-action="Leaderboard" class="auth-box">Leaderboard</a>
    </div>

    <div class="auth-container" style="display:flex; gap:12px; align-items:center;">
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <a asp-controller="Home" asp-action="Profile" class="auth-box">Profile</a>
            <form method="post" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index","Home")" class="auth-form">
                <button type="submit" class="auth-box">Logout</button>
            </form>
        }
        else
        {
            <a asp-area="Identity" asp-page="/Account/Login" class="auth-box">Login</a>
            <a asp-area="Identity" asp-page="/Account/Register" class="auth-box">Register</a>
        }
    </div>
</div>

<div class="homepage">
    <div class="logo-container" style="margin-bottom: 70px;">
        <h1 class="game-title">FNaFle</h1>
        <p class="subtitle">Can you beat the night?</p>
    </div>

    <div class="modes-vertical" style="gap: 25px;">
        <a asp-controller="Game" asp-action="Play" class="mode-button classic"><span>Classic</span></a>

        <a asp-controller="Map" asp-action="Index" class="mode-button camera"><span>Camera</span></a>

        <a href="#" class="mode-button lore"><span>Lore</span></a>
        <a href="#" class="mode-button infinite"><span>Infinite</span></a>
        <a href="Ranked" class="mode-button ranked"><span>Ranked</span></a>
    </div>

    <div class="rules-box" style="margin-top: 80px;">
        <strong>Game Rules:</strong><br />
        Survive each night by managing your resources and avoiding animatronics.<br />
        Use cameras wisely and keep track of your power to last until 6 AM.
    </div>

    <footer class="footer">
        <p>Not affiliated with Scott Cawthon or FNaF. Made for fun.</p>
    </footer>
</div>