@model IEnumerable<FNaFle.Models.LeaderboardUserViewModel>

@{
    ViewData["Title"] = "Leaderboard";
}

<div class="library-page">

    <div class="library-header">
        <a asp-controller="Home" asp-action="Index" class="auth-box">
            Home
        </a>

        <h1 class="library-title">Global Leaderboard</h1>

        <div style="width: 100px;"></div>
    </div>

    <div class="leaderboard-container">
        @{
            int rank = 1;
        }
        @foreach (var user in Model)
        {
            <div class="leaderboard-item">
                <div class="rank-badge">#@rank</div>

                <div class="player-info">
                    @* This displays the Username you just set in your Profile! *@
                    <span class="player-name">@user.Username</span>
                </div>

                <div class="streak-box">
                    <span class="streak-label">STREAK</span>
                    <span class="streak-value">@user.Streak 🔥</span>
                </div>
            </div>
            rank++;
        }
    </div>
</div>

<style>
    .leaderboard-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 0 25px 60px;
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .leaderboard-item {
        display: flex;
        align-items: center;
        background: rgba(0, 0, 0, 0.45);
        border-radius: 14px;
        padding: 20px;
        border: 2px solid rgba(255, 0, 0, 0.35);
        box-shadow: inset 0 0 8px rgba(100,0,0,0.4), 0 0 12px rgba(255, 0, 0, 0.25);
        transition: transform .35s ease, border-color .35s ease;
    }

        .leaderboard-item:hover {
            transform: scale(1.02);
            border-color: #ff0000;
            box-shadow: 0 0 25px #ff0000, inset 0 0 12px #ff0000;
        }

    .rank-badge {
        font-size: 28px;
        font-weight: bold;
        color: #ff0000;
        text-shadow: 0 0 8px #ff0000;
        width: 80px;
    }

    .player-info {
        flex-grow: 1;
    }

    .player-name {
        font-size: 24px;
        color: white;
        text-shadow: 0 0 6px #ff0000;
        letter-spacing: 1px;
    }

    .streak-box {
        text-align: right;
    }

    .streak-label {
        display: block;
        font-size: 10px;
        color: #888;
        letter-spacing: 2px;
    }

    .streak-value {
        font-size: 22px;
        color: #fff;
        font-weight: bold;
    }
</style>