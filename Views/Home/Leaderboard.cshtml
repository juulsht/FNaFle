@model IEnumerable<FNaFle.Models.LeaderboardUserViewModel>
@{
    ViewData["Title"] = "Security Rankings";
    int rank = 1;
}

<div class="background-blur"></div>

<div class="top-bar">
    <div class="left-buttons" style="display:flex; gap:12px; align-items:center;">
        <a asp-controller="Home" asp-action="Index" class="auth-box">Back</a>
        <div class="night-box">
            <span class="night-label">System</span>
            <span class="night-value">RANKINGS</span>
        </div>
    </div>
</div>

<div class="homepage" style="padding-top: 100px;">
    <div class="logo-container">
        <h1 class="game-title">Leaderboard</h1>
        <p class="subtitle">Authorized Personnel Only</p>
    </div>

    <div class="leaderboard-wrapper">
        <div class="leaderboard-grid">
            @foreach (var user in Model)
            {
                <div class="leaderboard-card @(rank <= 3 ? "top-rank" : "")">
                    <div class="rank-num">#@rank</div>
                    <div class="user-details">
                        <span class="username-text">@user.Username</span>
                        <span class="status-text">ENCRYPTED DATA</span>
                    </div>
                    <div class="streak-data">
                        <span class="streak-count">@user.Streak</span>
                        <span class="streak-label">NIGHTS</span>
                    </div>
                </div>
                rank++;
            }
        </div>
    </div>
</div>

<style>
    /* The Magic Centering Logic */
    .leaderboard-wrapper {
        display: flex;
        justify-content: center; /* Horizontally centers the grid */
        width: 100%;
        padding: 20px 0 100px 0;
    }

    .leaderboard-grid {
        display: flex;
        flex-direction: column;
        gap: 12px;
        width: 100%;
        max-width: 650px; /* Keeps the cards from getting too wide */
    }

    .leaderboard-card {
        background: rgba(0, 0, 0, 0.85); /* Slightly darker for better readability */
        border: 2px solid rgba(255, 0, 0, 0.25);
        display: flex;
        align-items: center;
        padding: 15px 25px;
        border-radius: 8px;
        transition: 0.3s ease-in-out;
        box-shadow: 0 4px 15px rgba(0,0,0,0.5);
    }

        .leaderboard-card:hover {
            border-color: #ff0000;
            box-shadow: 0 0 20px rgba(255, 0, 0, 0.5);
            transform: scale(1.03);
        }

    /* Special Glow for Top 3 */
    .top-rank {
        border-color: rgba(255, 0, 0, 0.8);
        background: rgba(30, 0, 0, 0.7);
    }

    .rank-num {
        font-size: 2rem;
        font-weight: bold;
        color: #ff0000;
        width: 70px;
        text-shadow: 0 0 8px #ff0000;
    }

    .user-details {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        text-align: left;
    }

    .username-text {
        font-size: 1.4rem;
        color: white;
        letter-spacing: 1px;
    }

    .status-text {
        font-size: 0.65rem;
        color: #666;
        letter-spacing: 2px;
    }

    .streak-data {
        text-align: right;
    }

    .streak-count {
        display: block;
        font-size: 1.8rem;
        color: #fff;
        font-weight: bold;
        line-height: 1;
        text-shadow: 0 0 5px rgba(255,255,255,0.2);
    }

    .streak-label {
        font-size: 0.6rem;
        color: #ff0000;
        letter-spacing: 2px;
    }
</style>