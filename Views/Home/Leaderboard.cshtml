@model IEnumerable<FNaFle.Models.LeaderboardUserViewModel>
@{
    ViewData["Title"] = "Security Rankings";
    var streakLeaders = ViewBag.StreakLeaders as List<FNaFle.Models.LeaderboardUserViewModel>;
    // Since RankedLeaders in Controller was an anonymous type, we cast to dynamic or a compatible list
    var rankedLeaders = ViewBag.RankedLeaders as IEnumerable<dynamic>;
}

<div class="background-blur"></div>

<div class="top-bar">
    <div class="left-buttons" style="display:flex; gap:12px; align-items:center;">
        <a asp-controller="Home" asp-action="Index" class="auth-box">Back</a>
        <div class="night-box">
            <span class="night-label">System</span>
            <span class="night-value">RANKINGS</span>
        </div>
    </div>
</div>

<div class="homepage" style="padding-top: 100px;">
    <div class="logo-container">
        <h1 class="game-title">Leaderboard</h1>
        <p class="subtitle">Authorized Personnel Only</p>

        <div class="tab-system" style="margin-top: 30px; display: flex; gap: 10px; justify-content: center;">
            <button id="btn-streak" class="mode-button classic active-tab" onclick="switchTab('streak')">
                <span>Classic Streaks</span>
            </button>
            <button id="btn-ranked" class="mode-button ranked" onclick="switchTab('ranked')">
                <span>Ranked Points</span>
            </button>
        </div>
    </div>

    <div class="leaderboard-wrapper">
        <div id="section-streak" class="leaderboard-grid">
            @{
                int sRank = 1;
            }
            @foreach (var user in streakLeaders ?? new List<FNaFle.Models.LeaderboardUserViewModel>())
            {
                <div class="leaderboard-card @(sRank <= 3 ? "top-rank" : "")">
                    <div class="rank-num">#@sRank</div>
                    <div class="user-details">
                        <span class="username-text">@user.Username</span>
                        <span class="status-text">STREAK DATA VERIFIED</span>
                    </div>
                    <div class="streak-data">
                        <span class="streak-count">@user.Streak</span>
                        <span class="streak-label">NIGHTS</span>
                    </div>
                </div>
                sRank++;
            }
        </div>

        <div id="section-ranked" class="leaderboard-grid" style="display:none;">
            @{
                int rRank = 1;
            }
            @foreach (var user in rankedLeaders ?? Enumerable.Empty<dynamic>())
            {
                <div class="leaderboard-card @(rRank <= 3 ? "top-rank-gold" : "")">
                    <div class="rank-num">#@rRank</div>
                    <div class="user-details">
                        <span class="username-text">@user.Username</span>
                        <span class="status-text">RANKED ANALYSIS POINTS</span>
                    </div>
                    <div class="streak-data">
                        <span class="streak-count" style="color: #ffaa00;">@user.Points</span>
                        <span class="streak-label">POINTS</span>
                    </div>
                </div>
                rRank++;
            }
        </div>
    </div>
</div>

<style>
    /* Tab Styling */
    .active-tab {
        border-color: #ff0000 !important;
        box-shadow: 0 0 15px rgba(255, 0, 0, 0.6) !important;
        background: rgba(255, 0, 0, 0.1) !important;
    }

    .leaderboard-wrapper {
        display: flex;
        justify-content: center;
        width: 100%;
        padding: 20px 0 100px 0;
    }

    .leaderboard-grid {
        display: flex;
        flex-direction: column;
        gap: 12px;
        width: 100%;
        max-width: 650px;
    }

    .leaderboard-card {
        background: rgba(0, 0, 0, 0.85);
        border: 2px solid rgba(255, 0, 0, 0.25);
        display: flex;
        align-items: center;
        padding: 15px 25px;
        border-radius: 8px;
        transition: 0.3s ease-in-out;
        box-shadow: 0 4px 15px rgba(0,0,0,0.5);
    }

        .leaderboard-card:hover {
            border-color: #ff0000;
            box-shadow: 0 0 20px rgba(255, 0, 0, 0.5);
            transform: scale(1.02);
        }

    .top-rank {
        border-color: rgba(255, 0, 0, 0.8);
        background: rgba(40, 0, 0, 0.4);
    }

    .top-rank-gold {
        border-color: #ffaa00;
        background: rgba(50, 40, 0, 0.3);
    }

    .rank-num {
        font-size: 2rem;
        font-weight: bold;
        color: #ff0000;
        width: 70px;
        text-shadow: 0 0 8px #ff0000;
    }

    .user-details {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        text-align: left;
    }

    .username-text {
        font-size: 1.4rem;
        color: white;
        letter-spacing: 1px;
    }

    .status-text {
        font-size: 0.65rem;
        color: #666;
        letter-spacing: 2px;
    }

    .streak-data {
        text-align: right;
    }

    .streak-count {
        display: block;
        font-size: 1.8rem;
        color: #fff;
        font-weight: bold;
        line-height: 1;
    }

    .streak-label {
        font-size: 0.6rem;
        color: #ff0000;
        letter-spacing: 2px;
    }
</style>

<script>
    function switchTab(mode) {
        const streakSec = document.getElementById('section-streak');
        const rankedSec = document.getElementById('section-ranked');
        const btnStreak = document.getElementById('btn-streak');
        const btnRanked = document.getElementById('btn-ranked');

        if (mode === 'streak') {
            streakSec.style.display = 'flex';
            rankedSec.style.display = 'none';
            btnStreak.classList.add('active-tab');
            btnRanked.classList.remove('active-tab');
        } else {
            streakSec.style.display = 'none';
            rankedSec.style.display = 'flex';
            btnRanked.classList.add('active-tab');
            btnStreak.classList.remove('active-tab');
        }
    }
</script>