@model FNaFle.Models.Character
@{
    ViewData["Title"] = "Delete " + Model.Name;
}

<div class="delete-page">

    <div class="delete-card">

        <h1 class="delete-title">Delete Character</h1>

        <div class="delete-warning">
            <h2 class="delete-name">@Model.Name</h2>

            <p class="delete-text">
                Are you sure you want to <span class="danger-text">permanently delete</span> this character?
            </p>

            <div class="delete-image-box">
                @if (!string.IsNullOrWhiteSpace(Model.ImagePath))
                {
                    <img src="@Model.ImagePath" class="delete-image" />
                }
                else
                {
                    <div class="delete-image placeholder">No Image</div>
                }
            </div>
        </div>

        <form method="post" class="delete-form">
            <input type="hidden" asp-for="Id" />

            <div class="delete-actions">
                <button type="submit" class="auth-box delete-btn">Delete</button>
                <a asp-action="Index" class="auth-box">Cancel</a>
            </div>
        </form>

    </div>

</div>

<style>

    /* Page wrapper */
    .delete-page {
        padding-top: 140px;
        display: flex;
        justify-content: center;
        padding-bottom: 60px;
    }

    /* Delete card */
    .delete-card {
        width: min(550px, 92vw);
        background: rgba(0, 0, 0, 0.65);
        border: 2px solid rgba(255, 0, 0, 0.45);
        border-radius: 16px;
        padding: 30px 35px;
        box-shadow: 0 0 28px rgba(255, 0, 0, 0.35);
        text-align: center;
        color: white;
    }

    /* Header */
    .delete-title {
        font-size: 36px;
        margin-bottom: 20px;
        color: #ff0000;
        text-shadow: 0 0 14px #ff0000, 0 0 26px #ff0000;
    }

    /* Character name */
    .delete-name {
        font-size: 28px;
        margin-bottom: 10px;
        color: #ff7070;
        text-shadow: 0 0 10px rgba(255, 80, 80, 0.7);
    }

    /* Warning text */
    .delete-text {
        font-size: 18px;
        margin-bottom: 25px;
        opacity: 0.85;
    }

    .danger-text {
        color: #ff3b3b;
        font-weight: bold;
        text-shadow: 0 0 8px #ff3b3b;
    }

    /* Image preview */
    .delete-image-box {
        margin: 0 auto 25px auto;
        width: 100%;
        max-height: 260px;
        overflow: hidden;
        border-radius: 10px;
        border: 1px solid rgba(255,0,0,0.3);
        box-shadow: 0 0 15px rgba(255,0,0,0.25);
    }

    .delete-image {
        width: 100%;
        display: block;
    }

        .delete-image.placeholder {
            height: 200px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #999;
            background: rgba(20, 0, 0, 0.6);
        }

    /* Buttons */
    .delete-actions {
        display: flex;
        justify-content: center;
        gap: 20px;
        margin-top: 18px;
    }

    /* Delete button special red glowing style */
    .delete-btn {
        background: rgba(70, 0, 0, 0.7);
        border-color: rgba(255, 0, 0, 0.7) !important;
        box-shadow: 0 0 16px rgba(255, 0, 0, 0.5);
    }

        .delete-btn:hover {
            background: rgba(120, 0, 0, 0.9);
            box-shadow: 0 0 26px #ff0000;
        }

</style>
