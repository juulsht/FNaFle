@model FNaFle.Models.Character
@{
    ViewData["Title"] = "Delete " + Model.Name;
}

<h1>Delete @Model.Name</h1>

<p>Are you sure you want to delete this character?</p>

<form method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="auth-box">Delete</button>
    <a asp-action="Index" class="auth-box">Cancel</a>
</form>
