@{
    Layout = "_Layout";
    ViewData["Title"] = "Play FNaFle";
    var results = ViewBag.Results as Dictionary<string, string>;
    var previousGuesses = ViewBag.PreviousGuesses as List<Dictionary<string, string>>;
    var dailyCharacter = ViewBag.DailyCharacter;
    var isCorrectGuess = ViewBag.IsCorrectGuess as bool? ?? false;

    if (previousGuesses == null) previousGuesses = new List<Dictionary<string, string>>();
}

<div class="background-blur"></div>

<div class="homepage">

    <div class="logo-container">
        <h1 class="game-title">FNaFle</h1>
        <p class="subtitle">Can you beat the night?</p>
    </div>

    <form asp-action="Play" method="post" style="margin-bottom: 30px;">
        <input type="text" name="guessName" placeholder="Enter character name"
               class="mode-input"
               style="padding: 12px 15px; width: 260px; border-radius: 10px; border: 2px solid #ff000080; background-color: #111; color: white; text-align: center; font-size: 16px;" required />
        <button type="submit" class="mode-button classic" style="margin-left:10px;"><span>Guess</span></button>
    </form>

    @if (ViewBag.Error != null)
    {
        <p style="color:#ff0000; font-weight:bold; text-shadow:0 0 10px #ff0000;">@ViewBag.Error</p>
    }

    @if (isCorrectGuess)
    {
        <p style="color:#00FF00; font-weight:bold; font-size:20px; text-shadow:0 0 15px #00FF00;">
            Great! You guessed it!
        </p>
    }
    else if (results != null)
    {
        <h2 style="margin-top:20px; text-shadow:0 0 10px #ff0000;">
            Your Last Guess:
            <span style="color:#FFD700;">@ViewBag.GuessName</span>
        </h2>

        <div class="guess-row" style="display:flex; justify-content:center; gap:15px; flex-wrap:wrap; margin-top:20px;">
            @{
                int delay = 0;
                foreach (var kvp in results)
                {
                    var isCorrect = kvp.Value == (kvp.Key switch
                    {
                        "Gender" => dailyCharacter.Gender,
                        "Generation" => dailyCharacter.Generation,
                        "Species" => dailyCharacter.Species,
                        "Location" => dailyCharacter.Location,
                        "Status" => dailyCharacter.Status,
                        _ => null
                    });

                    var boxClass = isCorrect ? "box-correct" : "box-wrong";
                    <div class="reveal-box @boxClass" style="animation-delay:@($"{delay * 0.3}s")">
                        <div class="attr-key">@kvp.Key</div>
                        <div class="attr-value">@kvp.Value</div>
                    </div>
                    ;
                    delay++;
                }
            }
        </div>

        @if (previousGuesses.Count > 0)
        {
            <h3 style="margin-top:40px; color:#ff4444; text-shadow:0 0 10px #ff0000;">Previous Guesses</h3>
            <div style="display:flex; flex-direction:column; align-items:center; gap:20px; margin-top:15px;">
                @foreach (var guess in previousGuesses)
                {
                    <div class="guess-row" style="display:flex; justify-content:center; gap:15px; flex-wrap:wrap;">
                        @{
                            int delayPrev = 0;
                            foreach (var kvp in guess)
                            {
                                var isCorrect = kvp.Value == (kvp.Key switch
                                {
                                    "Gender" => dailyCharacter.Gender,
                                    "Generation" => dailyCharacter.Generation,
                                    "Species" => dailyCharacter.Species,
                                    "Location" => dailyCharacter.Location,
                                    "Status" => dailyCharacter.Status,
                                    _ => null
                                });

                                var boxClass = isCorrect ? "box-correct" : "box-wrong";
                                <div class="reveal-box @boxClass" style="animation-delay:@($"{delayPrev * 0.15}s")">
                                    <div class="attr-key">@kvp.Key</div>
                                    <div class="attr-value">@kvp.Value</div>
                                </div>
                                ;
                                delayPrev++;
                            }
                        }
                    </div>
                }
            </div>
        }
    }
</div>
