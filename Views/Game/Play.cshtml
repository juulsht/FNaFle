@{
    Layout = "_Layout";
    ViewData["Title"] = "Play FNaFle";

    var results = ViewBag.Results as Dictionary<string, string>;
    var character = ViewBag.Character;
    var guessedCorrectlyToday = ViewBag.GuessedCorrectlyToday as bool? ?? false;
}

<div class="background-blur"></div>

<!-- ✅ TOP BAR WITH HOME BUTTON -->
<div class="top-bar">
    <div class="left-buttons" style="display:flex; gap:12px; align-items:center;">
        <a asp-controller="Home" asp-action="Index" class="auth-box">
            Home
        </a>
    </div>
</div>

<div class="homepage">

    <div class="logo-container">
        <h1 class="game-title">FNaFle</h1>
        <p class="subtitle">Can you beat the night?</p>
    </div>

    @if (!guessedCorrectlyToday)
    {
        <form asp-action="Play" method="post" style="margin-bottom: 30px;">
            <input type="text" name="guess" placeholder="Enter character name"
                   class="mode-input"
                   style="padding: 12px 15px; width: 260px; border-radius: 10px; border: 2px solid #ff000080; background-color: #111; color: white; text-align: center; font-size: 16px;" required />

            <button type="submit" class="mode-button classic" style="margin-left:10px;">
                <span>Guess</span>
            </button>
        </form>
    }
    else
    {
        <p style="color:#00ff00; font-weight:bold; font-size:22px; text-shadow:0 0 10px #00ff00;">
            🎉 You already guessed today's character — return tomorrow after 08:00!
        </p>
    }

    @if (ViewBag.Error != null)
    {
        <p style="color:#ff0000; font-weight:bold; text-shadow:0 0 10px #ff0000;">
            @ViewBag.Error
        </p>
    }

    @if (ViewBag.Message != null)
    {
        <p style="
            margin-top:15px;
            font-size:20px;
            font-weight:bold;
            text-shadow:0 0 10px;
            color:@(ViewBag.Message.ToString().Contains("Correct") ? "lightgreen" : "red");
                ">
            @ViewBag.Message
        </p>
    }

    @if (results != null)
    {
        <h2 style="margin-top:20px; text-shadow:0 0 10px #ff0000;">
            Your Guess: <span style="color:#ff0000;">@ViewBag.GuessName</span>
        </h2>

        <div class="guess-row" style="display:flex; justify-content:center; gap:15px; flex-wrap:wrap; margin-top:20px;">
            @{
                foreach (var kvp in results)
                {
                    var isCorrect = kvp.Value == (kvp.Key switch
                    {
                        "Gender" => character.Gender,
                        "Generation" => character.Generation,
                        "Species" => character.Species,
                        "Location" => character.Location,
                        "Status" => character.Status,
                        _ => null
                    });

                    var boxClass = isCorrect ? "box-correct" : "box-wrong";

                    <div class="reveal-box @boxClass">
                        <div class="attr-key">@kvp.Key</div>
                        <div class="attr-value">@kvp.Value</div>
                    </div>
                }
            }
        </div>
    }
</div>
