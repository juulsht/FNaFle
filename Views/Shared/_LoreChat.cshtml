<div id="lore-chat-container" style="position:fixed; bottom:20px; right:20px; z-index:1000; font-family:'Courier New',monospace;">

    <button id="chat-toggle" class="auth-box" onclick="toggleChat()"
            style="width:60px;height:60px;border-radius:50%;padding:0;display:flex;justify-content:center;align-items:center;box-shadow:0 0 15px #f00;">
        <span style="font-size:24px;">?</span>
    </button>

    <div id="chat-window" class="cctv-frame"
         style="display:none;position:absolute;bottom:80px;right:0;width:360px;height:460px;flex-direction:column;background:#000;border:4px solid #1a1a1a;">

        <div style="background:#1a1a1a;padding:10px;display:flex;justify-content:space-between;align-items:center;border-bottom:2px solid #f00;">
            <span style="color:#f00;font-weight:bold;font-size:12px;">
                FAZBEAR_ARCHIVE_TERMINAL
            </span>
            <button onclick="toggleChat()" style="background:none;border:none;color:#f00;cursor:pointer;">
                [X]
            </button>
        </div>

        <div id="chat-history"
             style="flex-grow:1;overflow-y:auto;padding:15px;font-size:13px;color:#0f0;line-height:1.5;">

            <p>> CONNECTION ESTABLISHED...</p>
            <p>> ACCESSING FAZ-NET DATABASE...</p>
            <p>> READY FOR INPUT.</p>

        </div>

        <div style="padding:10px;background:#0a0a0a;border-top:1px solid #333;">
            <div style="display:flex;gap:5px;">
                <input type="text"
                       id="chat-input"
                       placeholder="Enter inquiry..."
                       style="flex-grow:1;background:#000;border:1px solid #444;color:#0f0;padding:8px;font-size:12px;outline:none;">

                <button onclick="sendLoreMessage()"
                        class="auth-box"
                        style="padding:5px 10px;font-size:10px;">
                    SEND
                </button>
            </div>
        </div>

    </div>
</div>

<style>

    #chat-history div {
        margin-bottom: 10px;
    }

    .glitch {
        animation: glitch 0.2s infinite;
    }

    @@keyframes glitch {
        0%

    {
        text-shadow: 2px 0 red;
    }

    50% {
        text-shadow: -2px 0 blue;
    }

    100% {
        text-shadow: 2px 0 red;
    }

    }
</style>

<script>

    function toggleChat(){
    const win=document.getElementById("chat-window");
    win.style.display=(win.style.display==="none"||win.style.display==="")?"flex":"none";
    }

    function scrollBottom(){
    const history=document.getElementById("chat-history");
    history.scrollTop=history.scrollHeight;
    }

    function typeText(element,text,speed=15){

    element.innerHTML="";
    let i=0;

    function typing(){

    if(i<text.length){
    element.innerHTML+=text.charAt(i);
    i++;
    scrollBottom();
    setTimeout(typing,speed);
    }

    }

    typing();

    }

    function sendLoreMessage(){

    const input=document.getElementById("chat-input");
    const history=document.getElementById("chat-history");
    const msg=input.value.trim();

    if(!msg) return;

    history.innerHTML+=`<div style="color:#fff;">> USER: ${msg}</div>`;

    input.value="";
    scrollBottom();

    const loading=document.createElement("div");
    loading.innerHTML="> SYSTEM: ACCESSING ARCHIVES...";
    history.appendChild(loading);

    scrollBottom();

    fetch('/Chat/AskLore',{
    method:'POST',
    headers:{'Content-Type':'application/x-www-form-urlencoded'},
    body:new URLSearchParams({'message':msg})
    })
    .then(res=>res.json())
    .then(data=>{

    loading.remove();

    const replyBox=document.createElement("div");
    replyBox.innerHTML="> SYSTEM: ";

    history.appendChild(replyBox);

    const textSpan=document.createElement("span");
    replyBox.appendChild(textSpan);

    typeText(textSpan,data.reply);

    if(Math.random()<0.25){
    replyBox.classList.add("glitch");
    }

    scrollBottom();

    })
    .catch(()=>{

    loading.innerHTML="> ERROR: CONNECTION LOST";

    });

    }

    document.getElementById("chat-input")?.addEventListener("keypress",function(e){
    if(e.key==="Enter"){
    sendLoreMessage();
    }
    });

</script>