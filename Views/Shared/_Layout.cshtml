@* Views/Shared/_Layout.cshtml *@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FNaFle</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        table {
            border-collapse: collapse;
            margin-top: 20px;
            font-family: Arial, sans-serif;
        }

        th, td {
            border: 1px solid black;
            padding: 10px 15px;
            text-align: center;
        }

        input[type="text"] {
            padding: 8px;
            width: 250px;
            margin-right: 10px;
        }

        button {
            padding: 8px 12px;
            cursor: pointer;
        }
    </style>
</head>

<body>
    @RenderBody()

    @RenderSection("Scripts", required: false)
</body>
</html>
