@model FNaFle.Models.Character
@{
    Layout = "_Layout";
    ViewData["Title"] = "Ranked Mode";

    var target = ViewBag.Character as FNaFle.Models.Character;
    var history = ViewBag.History as List<FNaFle.Models.Character> ?? new List<FNaFle.Models.Character>();
    var guessedCorrectlyToday = ViewBag.GuessedCorrectlyToday as bool? ?? false;

    int maxTries = 3;
    int historyCount = history.Count;
    int livesLeft = maxTries - historyCount;
}

<div class="background-blur"></div>

<div class="top-bar">
    <div class="left-buttons" style="display:flex; gap:12px; align-items:center;">
        <a asp-controller="Home" asp-action="Index" class="auth-box" style="text-decoration:none;">Home</a>
    </div>
</div>

<div class="homepage">
    <div class="logo-container">
        <h1 class="game-title">FNaFle</h1>
        <p class="subtitle">Ranked: @livesLeft Tries Remaining</p>
    </div>

    @if (!guessedCorrectlyToday && livesLeft > 0)
    {
        <form asp-controller="Ranked" asp-action="Play" method="post" style="margin-bottom: 30px;">
            <input type="text" name="guess" placeholder="Enter character name"
                   class="mode-input"
                   style="padding: 12px 15px; width: 260px; border-radius: 10px; border: 2px solid #ff000080; background-color: #111; color: white; text-align: center; font-size: 16px;" required />

            <button type="submit" class="mode-button classic" style="margin-left:10px;">
                <span>Guess</span>
            </button>
        </form>
    }
    else if (guessedCorrectlyToday)
    {
        <p style="color:#00ff00; font-weight:bold; font-size:22px; text-shadow:0 0 10px #00ff00;">
            🎉 Security clearance granted — Return tomorrow!
        </p>
    }
    else
    {
        <p style="color:#ff0000; font-weight:bold; font-size:22px; text-shadow:0 0 10px #ff0000;">
            ❌ Connection lost — System reboot required tomorrow.
        </p>
    }

    @if (ViewBag.Error != null)
    {
        <p style="color:#ff0000; font-weight:bold; text-shadow:0 0 10px #ff0000;">@ViewBag.Error</p>
    }

    @if (ViewBag.Message != null)
    {
        <p style="margin-top:15px; font-size:20px; font-weight:bold; text-shadow:0 0 10px; color:@(ViewBag.Message.ToString().Contains("Correct") ? "lightgreen" : "red");">
            @ViewBag.Message
        </p>
    }

    <div class="history-list" style="display:flex; flex-direction:column; align-items:center; gap:12px; margin-top:30px; width:100%;">
        @for (int i = 0; i < historyCount; i++)
        {
            var g = history[i];

            /* The 'trick' to keep corruption locked:
            Calculate which guess this was chronologically.
                First guess ever made (at the end of the list) is 1.
                Newest guess (at index 0) is historyCount.
                */
            int guessAttemptNumber = historyCount - i;

        bool hideLocation = (guessAttemptNumber == 1);
        bool hideSpecies = (guessAttemptNumber == 2);
        bool hideGen = (guessAttemptNumber == 3);

        <div class="guess-row" style="display:flex; gap:10px; justify-content:center; align-items:center; width:100%; max-width:900px;">

            <div class="reveal-box" style="padding:0; overflow:hidden; border:2px solid #444;">
                <img src="@g.ImagePath" style="width:100%; height:100%; object-fit:cover;" onerror="this.src='/images/placeholder.png'" />
            </div>

            <div class="reveal-box @(g.Name == target.Name ? "box-correct" : "box-wrong")">
                <div class="attr-key">Name</div>
                <div class="attr-value">@g.Name</div>
            </div>

            <div class="reveal-box @(g.Gender == target.Gender ? "box-correct" : "box-wrong")">
                <div class="attr-key">Gender</div>
                <div class="attr-value">@g.Gender</div>
            </div>

            <div class="reveal-box @(hideGen ? "box-corrupt" : (g.Generation == target.Generation ? "box-correct" : "box-wrong"))">
                <div class="attr-key">Gen</div>
                <div class="attr-value">@(hideGen ? "???" : g.Generation)</div>
            </div>

            <div class="reveal-box @(hideSpecies ? "box-corrupt" : (g.Species == target.Species ? "box-correct" : "box-wrong"))">
                <div class="attr-key">Species</div>
                <div class="attr-value">@(hideSpecies ? "???" : g.Species)</div>
            </div>

            <div class="reveal-box @(hideLocation ? "box-corrupt" : (g.Location == target.Location ? "box-correct" : "box-wrong"))">
                <div class="attr-key">Location</div>
                <div class="attr-value" style="font-size:11px;">@(hideLocation ? "???" : g.Location)</div>
            </div>
        </div>
            }
    </div>
</div>

<style>
    .history-list {
        padding-bottom: 50px;
    }

    .reveal-box {
        width: 100px;
        height: 100px;
        background: rgba(0,0,0,0.6);
        border: 2px solid #333;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        border-radius: 8px;
        color: white;
        flex-shrink: 0;
    }

    .box-correct {
        background-color: #198754 !important;
        border-color: #2fb370 !important;
    }

    .box-wrong {
        background-color: #bb2d3b !important;
        border-color: #dc3545 !important;
    }

    .attr-key {
        font-size: 10px;
        text-transform: uppercase;
        opacity: 0.6;
        margin-bottom: 4px;
        font-family: monospace;
    }

    .attr-value {
        font-weight: bold;
        font-size: 13px;
        word-wrap: break-word;
        max-width: 90%;
    }

    .box-corrupt {
        background-color: #000 !important;
        border: 2px dashed #555 !important;
        color: #ff0000 !important;
        text-shadow: 0 0 5px red;
    }
</style>